generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model User {
  id          String      @id // Supabase auth user UUID
  name        String?
  email       String      @unique
  image       String?
  clients     Client[]
  invoices    Invoice[]
  timeEntries TimeEntry[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("billforge_users")
  @@schema("public")
}

model Client {
  id        String    @id @default(cuid())
  userId    String
  name      String
  email     String
  company   String?
  phone     String?
  address   String?
  notes     String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, createdAt])
  @@map("billforge_clients")
  @@schema("public")
}

model Project {
  id          String      @id @default(cuid())
  clientId    String
  name        String
  description String?
  hourlyRate  Float?
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  timeEntries TimeEntry[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([clientId])
  @@map("billforge_projects")
  @@schema("public")
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  clientId      String
  projectId     String?
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  subtotal      Float
  tax           Float         @default(0)
  total         Float
  currency      String        @default("INR")
  notes         String?
  paidAt        DateTime?
  paymentLink   String?
  pdfUrl        String?
  recurring     Boolean       @default(false)
  recurInterval String?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project       Project?      @relation(fields: [projectId], references: [id])
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, invoiceNumber])
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([dueDate])
  @@map("billforge_invoices")
  @@schema("public")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED

  @@map("billforge_invoice_status")
  @@schema("public")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  rate        Float
  amount      Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("billforge_invoice_items")
  @@schema("public")
}

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  projectId   String
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  billable    Boolean   @default(true)
  billed      Boolean   @default(false)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, startTime])
  @@index([projectId, billed])
  @@map("billforge_time_entries")
  @@schema("public")
}
